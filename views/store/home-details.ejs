<%- include('../common/head') %>
    <body>
        <%- include('../common/nav') %>
        <main>
            <div class="flex flex-col justify-center">
                <div class="w-1/2 mx-auto bg-white rounded-lg shadow-lg overflow-hidden mt-8 p-8 flex flex-col md:flex-row">
                    <div class="md:w-1/2 flex justify-center items-center">
                        <img src="<%= home.image %>" alt="<%= home.name %>" class="rounded-lg shadow-lg w-full h-72 object-cover" />
                    </div>
                    <div class="md:w-1/2 md:pl-10 flex flex-col justify-center">
                        <h2 class="text-3xl font-bold text-gray-800 mb-4"><%= home.name %></h2>
                        <p class="text-lg text-gray-600 mb-2"><span class="font-semibold">Location:</span> <%= home.location %></p>
                        <p class="text-xl text-blue-600 font-semibold mb-4">₹<%= home.price.toLocaleString() %> / per night</p>
                        <p class="text-gray-700 mb-6"><%= home.description %></p>
                        <form action="/add-to-favorite/<%= home.id %>" method="post">
                            <input type="hidden" name="home_id" value="<%= home.id %>">
                            <button type="submit" class="bg-blue-500 text-white rounded-md p-2">Add to Favorite</button>
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </body>
</html>